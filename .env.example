# Configurações do Asaas
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_URL=https://sandbox.asaas.com/api/v3

# Segurança da licença
SECRET_WORD=your_secret_word_here

# Banco de dados
DATABASE_PATH=nfe_licensing.db

# Proteção do webhook (opcional)
WEBHOOK_TOKEN=your_webhook_token_here

# Callback para entrega automática de licença (opcional)
LICENSE_CALLBACK_URL=https://your-app.com/license-callback

# Porta para desenvolvimento local
PORT=5000